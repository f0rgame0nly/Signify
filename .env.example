# ===========================================
# SignBridge - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL Database Connection
# Example for local: postgresql://postgres:password@localhost:5432/signbridge
# Example for Neon:  postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/signbridge?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/signbridge

# Session secret (any random string)
SESSION_SECRET=change-me-to-a-random-string

# OpenAI API Key (get yours at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here
